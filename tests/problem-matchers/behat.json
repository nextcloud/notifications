{
	"problemMatcher": [
		{
			"owner": "behat",
			"pattern": [
				{
					"regexp": "^\\d+\\)\\s.*$"
				},
				{
					"regexp": "^(.*Failed\\sasserting\\sthat.*)$",
					"message": 1
				},
				{
					"regexp": "^\\s*$"
				},
				{
					"regexp": "^(.*/tests/.*\\.feature):(\\d+) \\(on line (\\d+)\\)\n$",
					"file": 1,
					"line": 3
				}
			]
		}
	]
}
