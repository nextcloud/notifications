{
	"problemMatcher": [
		{
			"owner": "behat",
			"severity": "error",
			"pattern": [
				{
					"regexp": "Failed scenarios:"
				},
				{
					"regexp": "^.*$"
				},
				{
					"regexp": "([^\\s]+(\\/tests\\/.*\\.feature):(\\d+)) \\(on line (\\d+)\\)",
					"message": 1,
					"file": 2,
					"line": 4,
					"loop": true
				}
			]
		}
	]
}
