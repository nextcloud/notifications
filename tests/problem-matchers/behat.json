{
	"problemMatcher": [
		{
			"owner": "behat",
			"severity": "error",
			"pattern": [
				{
					"regexp": "^.*--- Failed scenarios:$"
				},
				{
					"regexp": "^\\s*$"
				},
				{
					"regexp": "^(.*/tests/.*\\.feature):(\\d+) \\(on line (\\d+)\\)\n$",
					"file": 1,
					"line": 3,
					"loop": true
				}
			]
		}
	]
}
