{
	"problemMatcher": [
		{
			"owner": "behat",
			"severity": "error",
			"pattern": [
				{
					"regexp": "^.*--- Failed scenarios:$"
				},
				{
					"regexp": "^\\s*$"
				},
				{
					"regexp": "^((.*\\/tests\\/.*\\.feature):(\\d+)) \\(on line (\\d+)\\)\n$",
					"message": 1,
					"file": 2,
					"line": 4,
					"loop": true
				}
			]
		}
	]
}
